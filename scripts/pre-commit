#!/usr/bin/env bash
# Pre-commit hook: auto-fix formatting, then run the same checks as CI.
# Install: run `make setup`
set -euo pipefail

# Git sets GIT_DIR during hook execution. Unset it so that child
# processes (especially go test) don't inherit it — leaked GIT_DIR
# causes tests that create temp repos to operate on the wrong repository.
unset GIT_DIR GIT_WORK_TREE

# Auto-fix formatting and stage the changes.
make fmt
git add -u

# Run all quality gates (lint, fmt-check, vet, test).
exec make check
